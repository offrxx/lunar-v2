---
import '@/main.css';
import ImportLucide from '../layouts/lucide.astro';
import SettingsCard from '../components/opt.astro';

const presets = [
  { name: 'google', title: 'Google', img: '/a/images/co/go.ico', label: 'Google' },
  { name: 'drive', title: 'Google Drive', img: '/a/images/co/drei.png', label: 'Drive' },
  { name: 'classroom', title: 'Home', img: '/a/images/co/class.png', label: 'Class' },
  { name: 'gmail', title: 'Gmail', img: '/a/images/co/gmail.png', label: 'Gmail' },
  { name: 'youtube', title: 'YouTube', img: '/a/images/co/yt.png', label: 'YouTube' },
  { name: 'docs', title: 'Google Docs', img: '/a/images/co/docs.png', label: 'Docs' },
  { name: 'slack', title: 'Slack', img: '/a/images/co/slack.png', label: 'Slack' },
  { name: 'canvas', title: 'Dashboard', img: '/a/images/co/canvas.png', label: 'Canvas' },
];

const engines = [
  { value: 'https://duckduckgo.com/?q=', img: '/a/images/engines/ddg.ico', title: 'DuckDuckGo' },
  { value: 'https://www.google.com/search?q=', img: '/a/images/co/go.ico', title: 'Google' },
  { value: 'https://www.bing.com/search?q=', img: '/a/images/engines/bi.ico', title: 'Bing' },
  { value: 'https://search.brave.com/search?q=', img: '/a/images/engines/br.jpeg', title: 'Brave' },
];

let NAME: string;
if (STATIC) {
  NAME = 'Lunar Static';
} else {
  NAME = 'Lunar';
}
---

<html lang="en">
  <head>
    <title>Settings</title>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-DQZPCVEF89"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        window.dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-DQZPCVEF89');
    </script>
    <style>
      html,
      body,
      * {
        scrollbar-width: none !important;
        -ms-overflow-style: none !important;
      }
      html::-webkit-scrollbar,
      body::-webkit-scrollbar,
      *::-webkit-scrollbar {
        display: none !important;
        width: 0 !important;
        background: transparent !important;
      }
      .st .lucide {
        stroke-width: 2.15;
      }
      .toggle {
        transition:
          background-color 0.2s ease,
          box-shadow 0.2s ease;
      }
      .toggle:hover {
        box-shadow: 0 0 8px rgba(99, 102, 241, 0.2);
      }
    </style>
  </head>
  <body
    class="st bg-background font-linux text-text-header min-h-screen p-6 text-sm leading-relaxed md:p-8"
  >
    <div class="mx-auto max-w-5xl">
      <div class="flex gap-8">
        <nav class="hidden w-48 shrink-0 lg:block">
          <div class="sticky top-6 space-y-1">
            <header class="mb-6">
              <h1 class="mb-1 text-xl font-bold">Settings</h1>
              <p class="text-text-secondary text-xs">Customize {NAME}</p>
            </header>
            <a
              href="#privacy"
              class="nav-item flex items-center gap-2.5 rounded-lg bg-[#6366f1]/10 px-3 py-2 text-sm text-[#6366f1] transition-colors hover:bg-white/5"
              data-nav="privacy"
            >
              <i data-lucide="shield" class="h-4 w-4"></i>Privacy
            </a>
            <a
              href="#browsing"
              class="nav-item text-text-secondary hover:text-text-header flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors hover:bg-white/5"
              data-nav="browsing"
            >
              <i data-lucide="globe" class="h-4 w-4"></i>Browsing
            </a>
            <a
              href="#advanced"
              class="nav-item text-text-secondary hover:text-text-header flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors hover:bg-white/5"
              data-nav="advanced"
            >
              <i data-lucide="wrench" class="h-4 w-4"></i>Advanced
            </a>
            <a
              href="#about"
              class="nav-item text-text-secondary hover:text-text-header flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors hover:bg-white/5"
              data-nav="about"
            >
              <i data-lucide="info" class="h-4 w-4"></i>About
            </a>
          </div>
        </nav>
        <main class="flex-1 space-y-8">
          <section id="privacy" data-section="privacy">
            <h2 class="mb-4 flex items-center gap-2 text-base font-semibold">
              <i data-lucide="shield" class="h-5 w-5 text-[#6366f1]"></i>Privacy
            </h2>
            <div class="space-y-3">
              <SettingsCard
                type="card"
                title="About:Blank Cloak"
                desc="Opens Lunar in a blank tab to hide from history"
              >
                <SettingsCard
                  type="input"
                  name="aboutBlankUrl"
                  placeholder="Redirect URL (e.g. https://classroom.google.com)"
                  class="mb-3"
                />
                <SettingsCard type="btn" icon="external-link" action="about-blank" full
                  >Open in About:Blank</SettingsCard
                >
              </SettingsCard>

              <SettingsCard
                type="toggle"
                name="cloak"
                title="Tab Cloak"
                desc="Change tab title and icon"
              >
                <div data-cloak-inputs class="space-y-2.5 border-t border-white/5 pt-3">
                  <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
                    {
                      presets.map(p => (
                        <SettingsCard type="preset" name={p.name} title={p.title} img={p.img}>
                          {p.label}
                        </SettingsCard>
                      ))
                    }
                  </div>
                  <SettingsCard
                    type="input"
                    name="cloakTitle"
                    placeholder="Tab title"
                    disabled
                    class="cloak-input"
                  />
                  <SettingsCard
                    type="input"
                    name="cloakFavicon"
                    placeholder="Favicon URL"
                    disabled
                    class="cloak-input"
                  />
                </div>
              </SettingsCard>

              <SettingsCard
                type="toggle"
                name="tabSwitchCloak"
                title="Tab Switch Cloak"
                desc="Auto-cloak when you switch tabs"
              />
              <SettingsCard
                type="toggle"
                name="beforeUnload"
                title="Anti-close"
                desc="Confirm prompt before closing"
              />

              <SettingsCard
                type="toggle"
                name="panicKey"
                title="Panic Key"
                desc="Quick redirect with a keybind"
              >
                <div data-panic-inputs class="grid grid-cols-1 gap-2.5 sm:grid-cols-2">
                  <SettingsCard
                    type="input"
                    name="panicLoc"
                    placeholder="Redirect URL"
                    disabled
                    class="panic-input"
                  />
                  <SettingsCard
                    type="input"
                    name="panicKeyBind"
                    placeholder="Click to set keybind"
                    disabled
                    readonly
                    class="panic-input cursor-pointer"
                  />
                </div>
              </SettingsCard>
            </div>
          </section>
          <section id="browsing" data-section="browsing">
            <h2 class="mb-4 flex items-center gap-2 text-base font-semibold">
              <i data-lucide="globe" class="h-5 w-5 text-pink-400"></i>Browsing
            </h2>
            <div class="space-y-3">
              <SettingsCard type="card" title="Proxy Backend">
                <div class="grid grid-cols-2 gap-2.5">
                  <SettingsCard
                    type="proxy"
                    name="scramjet"
                    title="Scramjet"
                    desc="Experimental, faster"
                  />
                  <SettingsCard
                    type="proxy"
                    name="ultraviolet"
                    title="Ultraviolet"
                    desc="More stable, slower"
                  />
                </div>
              </SettingsCard>
              <SettingsCard type="card" title="Transport">
                <div class="grid grid-cols-2 gap-2.5">
                  <button
                    data-transport="ep"
                    class="bg-background/50 relative w-full rounded-lg border border-white/5 p-3 text-left transition-all duration-150 hover:scale-[1.02] hover:border-indigo-500/20 hover:bg-indigo-500/5 active:scale-[0.98]"
                  >
                    <div class="text-sm font-medium">Epoxy</div>
                    <div class="text-text-secondary text-xs">Slower</div>
                    <span class="proxy-check absolute top-2 right-2 hidden">
                      <i data-lucide="check-circle" class="h-4 w-4 text-[#6366f1]"></i>
                    </span>
                  </button>
                  <button
                    data-transport="lc"
                    class="bg-background/50 relative w-full rounded-lg border border-white/5 p-3 text-left transition-all duration-150 hover:scale-[1.02] hover:border-indigo-500/20 hover:bg-indigo-500/5 active:scale-[0.98]"
                  >
                    <div class="text-sm font-medium">Libcurl</div>
                    <div class="text-text-secondary text-xs">Fastest</div>
                    <span class="proxy-check absolute top-2 right-2 hidden">
                      <i data-lucide="check-circle" class="h-4 w-4 text-[#6366f1]"></i>
                    </span>
                  </button>
                </div>
              </SettingsCard>
              <SettingsCard type="card" title="Search Engine">
                <div class="mb-3 grid grid-cols-4 gap-2">
                  {
                    engines.map(e => (
                      <SettingsCard type="engine" value={e.value} img={e.img} title={e.title} />
                    ))
                  }
                </div>
                <SettingsCard
                  type="input"
                  name="engine"
                  placeholder="Custom search URL (ends with ?q=)"
                />
                <SettingsCard type="btn" reset="engine" class="mt-2.5">Reset</SettingsCard>
              </SettingsCard>

              <SettingsCard
                type="toggle"
                name="adBlock"
                title="Ad Block"
                desc="Block ads/trackers (experimental)"
              />
            </div>
          </section>
          <section id="advanced" data-section="advanced">
            <h2 class="mb-4 flex items-center gap-2 text-base font-semibold">
              <i data-lucide="wrench" class="h-5 w-5 text-amber-400"></i>Advanced
            </h2>
            <div class="space-y-3">
              <SettingsCard type="card" title="Wisp Server" desc="Change the websocket server URL">
                <SettingsCard type="input" name="wispUrl" placeholder="ws://localhost:3000/wisp/" />
                <SettingsCard type="btn" reset="wisp" class="mt-2.5">Reset</SettingsCard>
              </SettingsCard>

              <SettingsCard type="card">
                <h3 class="mb-1.5 flex items-center gap-1.5 text-sm font-medium">
                  <i data-lucide="alert-triangle" class="h-3.5 w-3.5 text-orange-400/80"></i>
                  Reset settings to default
                </h3>
                <p class="text-text-secondary mb-2.5 text-xs">This action cannot be undone</p>
                <SettingsCard type="btn" reset="reset">Reset</SettingsCard>
              </SettingsCard>
            </div>
          </section>
          <section id="about" data-section="about">
            <h2 class="mb-4 flex items-center gap-2 text-base font-semibold">
              <i data-lucide="info" class="h-5 w-5 text-[#6366f1]"></i>About
            </h2>
            <div class="space-y-3">
              <SettingsCard type="card">
                <div class="flex items-center gap-3">
                  <div
                    class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#6366f1]/15"
                  >
                    <i data-lucide="moon" class="h-5 w-5 text-[#6366f1]"></i>
                  </div>
                  <h3 class="text-base font-semibold">{NAME} v{VERSION}</h3>
                </div>
              </SettingsCard>

              <SettingsCard type="card">
                <h3 class="mb-3 flex items-center gap-1.5 text-xs font-semibold">
                  <i data-lucide="badge-info" class="h-3.5 w-3.5 text-[#6366f1]"></i>Credits
                </h3>
                <div class="space-y-3 text-xs">
                  <div>
                    <p
                      class="text-text-secondary mb-1.5 flex items-center gap-1.5 text-[10px] tracking-wide uppercase"
                    >
                      <i data-lucide="users" class="h-3 w-3"></i>Team
                    </p>
                    <div class="space-y-1.5">
                      <div class="flex items-center justify-between">
                        <a
                          href="https://github.com/bearcattt"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="transition-colors hover:text-[#6366f1]">Bearcattt</a
                        >
                        <span class="text-text-secondary">Founder</span>
                      </div>
                        <div class="flex items-center justify-between">
                        <a
                          href="https://github.com/cattreats"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="transition-colors hover:text-[#6366f1]">Shade</a
                        >
                        <span class="text-text-secondary">Owner & Moral Support</span>
                      </div>
                      <div class="flex items-center justify-between">
                        <a
                          href="https://github.com/not-amplify"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="transition-colors hover:text-[#6366f1]">Amplify</a
                        >
                        <span class="text-text-secondary">Co Owner & VPS host</span>
                      </div>
                    </div>
                  </div>
                  <div class="border-t border-white/5 pt-3">
                    <p
                      class="text-text-secondary mb-1.5 flex items-center gap-1.5 text-[10px] tracking-wide uppercase"
                    >
                      <i data-lucide="package" class="h-3 w-3"></i>Stack
                    </p>
                    <div class="space-y-1">
                      <div class="flex items-center justify-between">
                        <span>Frontend</span>
                        <span class="text-text-secondary">Astro, TypeScript, Tailwind</span>
                      </div>
                      <div class="flex items-center justify-between">
                        <span>Icons</span>
                        <span class="text-text-secondary">Lucide</span>
                      </div>
                    </div>
                  </div>
                </div>
              </SettingsCard>
            </div>
          </section>
        </main>
      </div>
    </div>
    <div
      id="reload-toast"
      class="bg-background-overlay/90 text-text-header pointer-events-none fixed right-6 bottom-6 translate-y-full rounded-xl border border-white/10 px-4 py-3 opacity-0 backdrop-blur-sm transition-all duration-300 ease-out"
      style="z-index:9999"
    >
      <p class="text-sm font-medium">Settings applied</p>
      <p class="text-text-secondary text-xs">Reload to apply changes</p>
    </div>
  </body>
  <ImportLucide />
  <script>
    import('../utils/st').then(({ SettingsManager }) => {
      SettingsManager.init();
      let reloadTimeout: ReturnType<typeof setTimeout> | null = null;
      SettingsManager.notify = function () {
        const el = document.getElementById('reload-toast');
        if (!el) return;
        if (reloadTimeout) {
          clearTimeout(reloadTimeout);
          reloadTimeout = null;
        }
        el.classList.add('opacity-0', 'pointer-events-none', 'translate-y-full');
        el.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
        setTimeout(() => {
          el.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-full');
          el.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
          reloadTimeout = setTimeout(() => {
            el.classList.add('opacity-0', 'pointer-events-none', 'translate-y-full');
            el.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
            reloadTimeout = null;
          }, 5000);
        }, 40);
      };
    });
  </script>
</html>
