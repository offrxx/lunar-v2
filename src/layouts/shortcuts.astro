---
import '@/main.css';
import ImportLucide from './lucide.astro';

type Shortcut = { name: string; url: string; icon: string | null; svg: string | null };

const shortcuts: Shortcut[] = [
  { name: 'Lunar Games', url: '/gkm', icon: 'gamepad-2', svg: null },
  {
    name: 'YouTube',
    url: 'https://youtube.com',
    icon: null,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-header)" class="h-5 w-5 transition-colors"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"></path><path d="m10 15 5-3-5-3z"></path></svg>`,
  },
  {
    name: 'GitHub',
    url: 'https://github.com',
    icon: null,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-header)" class="h-5 w-5 transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>`,
  },
  { name: 'AI', url: 'https://chatgpt.com', icon: 'bot', svg: null },
];
---

<div class="relative mt-12 flex w-full max-w-4xl flex-row items-center justify-center gap-5 px-3">
  {
    shortcuts.map(s => (
      <a
        href={s.url}
        data-short={s.url}
        class="shortcut-card group relative flex h-32 w-28 cursor-pointer flex-col items-center justify-center space-y-2 rounded-xl border p-3 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5"
        style="background-color: rgba(31, 29, 46, 0.45); border-color: rgba(99, 102, 241, 0.15);"
      >
        <div
          class="flex h-13 w-13 items-center justify-center rounded-full border transition-colors"
          style="background-color: rgba(58, 61, 96, 0.6); border-color: rgba(99, 102, 241, 0.2);"
        >
          {s.svg ? (
            <Fragment set:html={s.svg} />
          ) : (
            <i
              data-lucide={s.icon}
              style="color: var(--text-header);"
              class="h-5 w-5 transition-colors"
            />
          )}
        </div>
        <p class="text-center text-sm font-medium text-white/85 transition-colors group-hover:text-white">
          {s.name}
        </p>
      </a>
    ))
  }
</div>

<style>
  .shortcut-card {
    transition: all 300ms;
  }
  .shortcut-card:hover {
    opacity: 0.9;
  }
</style>
<script src="@scripts/shortcuts.ts"></script>
<ImportLucide />
