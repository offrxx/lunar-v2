---
import '@/main.css';
import ImportLucide from './lucide.astro';
const shortcuts = [
   {
    name: 'Lunar Games',
    url: '/gkm',
    icon: '/a/images/bm/gay.png',
  },
  {
    name: 'YouTube',
    url: 'https://youtube.com',
    icon: '/a/images/bm/yt.png',
  },
  {
    name: 'TikTok',
    url: 'https://tiktok.com',
    icon: '/a/images/bm/tictak.png',
  },
  {
    name: 'Snapchat',
    url: 'https://snapchat.com',
    icon: '/a/images/bm/snap.png',
  },
  {
    name: 'Discord',
    url: 'https://discord.com',
    icon: '/a/images/bm/disc.ico',
  },
];
---

<div class="relative mt-12 flex w-full max-w-4xl flex-row items-center justify-center gap-4 px-2">
  {
    shortcuts.map(shortcut => (
      <a
        data-short={shortcut.url}
        class="shortcut-card group relative flex w-32 cursor-pointer flex-col items-center justify-center space-y-3 rounded-lg border border-white/[0.08] bg-[#1e1e2f]/40 p-4 backdrop-blur-sm transition-all duration-200 hover:border-white/[0.15] hover:bg-[#1e1e2f]/60"
      >
        <div class="flex h-16 w-16 items-center justify-center overflow-hidden rounded-lg bg-[#252537]/60">
          <img
            src={shortcut.icon}
            class="shortcut-favicon h-10 w-10 object-contain"
            alt={shortcut.name + ' icon'}
          />
        </div>
        <p class="text-center text-sm font-medium text-white/60 transition-colors group-hover:text-white/85">
          {shortcut.name}
        </p>
      </a>
    ))
  }
</div>
<script src="@scripts/shortcuts.ts"></script>
<ImportLucide />
