---
import ImportLucide from './lucide.astro';
import '@/main.css';

const navButtons = [
  { id: 'back', icon: 'arrow-left' },
  { id: 'forward', icon: 'arrow-right' },
  {
    id: 'refresh',
    icon: 'refresh-cw',
    class: 'group',
    iconClass: 'transition-transform duration-500 group-hover:rotate-180',
  },
  { id: 'home', icon: 'house' },
];

const menuSections = [
  [
    { icon: 'plus', label: 'New Tab' },
    { icon: 'maximize-2', label: 'Full Screen' },
    { icon: 'refresh-cw', label: 'Reload' },
  ],
  [
    { icon: 'gamepad', label: 'Games' },
    { icon: 'code', label: 'Inspect Element' },
    { icon: 'moon', label: 'Dark Mode' },
    { icon: 'glasses', label: 'AB Cloak' },
  ],
  [
    { icon: 'log-out', label: 'Panic' },
    { icon: 'settings', label: 'Settings' },
  ],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="@scripts/tb.ts"></script>
    <script src="@scripts/menu.ts"></script>
    <script src="@scripts/suggestions.ts"></script>
    <style>
      #tcontainer::-webkit-scrollbar {
        height: 0;
      }

      @keyframes menu-in {
        from {
          opacity: 0;
          transform: scale(0.94) translateY(-6px);
        }
        to {
          opacity: 1;
          transform: scale(1) translateY(0);
        }
      }
      @keyframes menu-out {
        from {
          opacity: 1;
          transform: scale(1) translateY(0);
        }
        to {
          opacity: 0;
          transform: scale(0.94) translateY(-6px);
        }
      }
      @keyframes item-in {
        from {
          opacity: 0;
          transform: translateX(4px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }

      #menu.menu-opening {
        display: block !important;
        animation: menu-in 0.18s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        transform-origin: top right;
      }
      #menu.menu-closing {
        display: block !important;
        animation: menu-out 0.13s cubic-bezier(0.4, 0, 1, 1) forwards;
        transform-origin: top right;
      }
      #menu .menu-item {
        opacity: 0;
        transform: translateX(4px);
      }
      #menu.menu-opening .menu-item {
        animation: item-in 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
    </style>
  </head>

  <body class="bg-background text-text-header m-0 h-screen overflow-hidden p-0 font-sans">
    <div class="flex h-screen w-screen flex-col">
      <div id="tab-wrapper" class="bg-background flex h-11 items-end px-2 pt-1.5">
        <div class="flex w-full items-center gap-1">
          <div id="tcontainer" class="flex min-w-0 flex-nowrap items-end gap-0.5 overflow-x-auto">
          </div>
          <button
            id="add"
            class="text-text-secondary mb-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded transition hover:bg-panel-hover/75 hover:text-text-header"
          >
            <i data-lucide="plus" class="h-4 w-4"></i>
          </button>
        </div>
      </div>

      <div
        class="bg-background-overlay border-border-default/65 relative flex h-10 items-center gap-1.5 border-t px-3"
      >
        <div class="flex items-center gap-0.5">
          {
            navButtons.map(({ id, icon, class: btnClass, iconClass }) => (
              <button
                id={id}
                class:list={[
                  'text-text-secondary flex h-7 w-7 items-center justify-center rounded transition hover:bg-panel-hover/75 hover:text-text-header',
                  btnClass,
                ]}
              >
                <i data-lucide={icon} class:list={['h-3.5 w-3.5', iconClass]} />
              </button>
            ))
          }
        </div>

        <div class="bg-border-default/70 mx-0.5 h-4 w-px shrink-0"></div>

        <div class="relative z-50 min-w-0 flex-1">
          <div class="relative w-full">
            <span
              class="pointer-events-none absolute top-1/2 left-1.5 z-10 flex -translate-y-1/2 items-center"
            >
              <i
                data-lucide="lock"
                class="text-accent h-3.5 w-3.5"
                style="shape-rendering: geometricPrecision;"></i>
            </span>

            <div id="url-highlight" aria-hidden="true"></div>

            <input
              id="urlbar"
              type="text"
              autocomplete="off"
              spellcheck="false"
              class="border-border-default/55 text-text-header placeholder:text-text-secondary/60 relative h-7 w-full rounded-md border bg-transparent pr-7 pl-7 text-sm caret-white placeholder:text-sm hover:border-border-default/90 focus:outline-none"
              placeholder="Search or enter address"
            />

            <button
              id="fav"
              class="text-text-secondary absolute top-1/2 right-1 flex h-5 w-5 -translate-y-1/2 items-center justify-center rounded transition hover:bg-panel-hover/75 hover:text-text-header"
              style="z-index: 10; pointer-events: all;"
            >
              <i data-lucide="bookmark" class="h-3.5 w-3.5"></i>
            </button>

            <div
              id="suggestions"
              class="border-border-default/90 absolute top-full right-0 left-0 z-50 -mt-px hidden overflow-hidden rounded-b-lg border border-t-0 bg-[color:var(--background-overlay)] shadow-lg"
            >
              <div id="suggestions-container" class="py-1"></div>
            </div>
          </div>
        </div>

        <div class="bg-border-default/70 mx-0.5 h-4 w-px shrink-0"></div>

        <button
          id="menubtn"
          class="text-text-secondary flex h-7 w-7 shrink-0 items-center justify-center rounded transition hover:bg-panel-hover/75 hover:text-text-header"
        >
          <i data-lucide="menu" class="h-4 w-4" style="shape-rendering: geometricPrecision;"></i>
        </button>

        <div
          id="loading-bar"
          class="bg-accent pointer-events-none absolute right-0 bottom-0 left-0 z-50 hidden h-0.5 w-full opacity-0 transition-opacity duration-200"
        >
        </div>
      </div>

      <div class="relative flex-1 overflow-hidden">
        <div
          id="menu"
          class="border-border-default/90 absolute top-2 right-3 z-50 hidden w-64 overflow-hidden rounded-lg border bg-[color:var(--background-overlay)] shadow-2xl"
        >
          {
            menuSections.map((section, i) => (
              <div class:list={['flex flex-col', i !== 0 ? 'border-border-default border-t' : '']}>
                {section.map(({ icon, label }) => (
                  <button class="menu-item text-text-secondary/90 hover:text-text-header flex w-full items-center gap-2.5 px-3 py-2 transition hover:bg-panel-hover/80">
                    <i data-lucide={icon} class="h-3.5 w-3.5 shrink-0" />
                    <span class="text-xs">{label}</span>
                  </button>
                ))}
              </div>
            ))
          }
        </div>

        <div id="fcontainer" class="bg-background-overlay h-full w-full"></div>
      </div>

      <ImportLucide />
    </div>
  </body>
</html>
