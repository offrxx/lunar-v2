---
interface Props {
  type: 'toggle' | 'input' | 'btn' | 'card' | 'proxy' | 'engine' | 'preset';
  title?: string;
  desc?: string;
  name?: string;
  placeholder?: string;
  disabled?: boolean;
  readonly?: boolean;
  icon?: string;
  img?: string;
  full?: boolean;
  reset?: string;
  action?: string;
  value?: string;
  class?: string;
}

const {
  type,
  title,
  desc,
  name,
  placeholder,
  disabled = false,
  readonly = false,
  icon,
  img,
  full = false,
  reset,
  action,
  value,
  class: cls = '',
} = Astro.props;

const hasSlot = Astro.slots.has('default');
---

{
  type === 'toggle' && (
    <div
      class:list={[
        'bg-background-overlay/50 rounded-xl border border-white/5 p-4 transition-colors duration-200 hover:border-border-default/70 hover:bg-background-overlay/60',
        !hasSlot && 'flex items-center justify-between',
        cls,
      ]}
    >
      {!hasSlot ? (
        <>
          <div>
            <h3 class="text-sm font-medium">{title}</h3>
            {desc && <p class="text-text-secondary text-xs">{desc}</p>}
          </div>
          <div class="toggle" data-toggle={name} />
        </>
      ) : (
        <>
          <div class="mb-3 flex items-center justify-between">
            <div>
              <h3 class="text-sm font-medium">{title}</h3>
              {desc && <p class="text-text-secondary text-xs">{desc}</p>}
            </div>
            <div class="toggle" data-toggle={name} />
          </div>
          <slot />
        </>
      )}
    </div>
  )
}

{
  type === 'input' && (
    <input
      type="text"
      data-input={name}
      placeholder={placeholder}
      disabled={disabled}
      readonly={readonly}
      class:list={[
        'bg-background/70 w-full rounded-lg border border-white/5 px-3 py-2 text-sm transition-colors duration-150 hover:border-border-default/70 focus:border-[color:var(--accent)]/50 focus:ring-2 focus:ring-[color:var(--accent)]/15 focus:outline-none',
        disabled && 'disabled:opacity-40 disabled:hover:border-white/5',
        cls,
      ]}
    />
  )
}

{
  type === 'btn' && (
    <button
      data-reset={reset}
      data-action={action}
      class:list={[
        'bg-background/50 hover:bg-background/70 rounded-lg border border-white/5 transition-colors duration-150',
        full
          ? 'flex w-full items-center justify-center gap-2 px-3 py-2 text-sm'
          : 'px-3 py-1.5 text-xs',
        cls,
      ]}
    >
      {icon && <i data-lucide={icon} class="h-4 w-4" />}
      <slot />
    </button>
  )
}

{
  type === 'card' && (
    <div
      class:list={[
        'bg-background-overlay/50 rounded-xl border border-white/5 p-4 transition-colors duration-200 hover:border-border-default/70 hover:bg-background-overlay/60',
        cls,
      ]}
    >
      {title && <h3 class="mb-1.5 text-sm font-medium">{title}</h3>}
      {desc && <p class="text-text-secondary mb-3 text-xs">{desc}</p>}
      <slot />
    </div>
  )
}

{
  type === 'proxy' && (
    <button
      data-proxy={name}
      class="bg-background/50 relative rounded-lg border border-white/5 p-3 text-left transition-colors duration-150 hover:border-[color:var(--accent)]/35 hover:bg-[color:var(--accent)]/5"
    >
      <div class="text-sm font-medium">{title}</div>
      <div class="text-text-secondary text-xs">{desc}</div>
      <div class="proxy-check absolute top-2 right-2 hidden">
        <i data-lucide="check-circle" class="h-3.5 w-3.5 text-[color:var(--accent)]" />
      </div>
    </button>
  )
}

{
  type === 'engine' && (
    <button
      data-engine={value}
      class="bg-background/50 relative flex items-center justify-center gap-1.5 rounded-lg border border-white/5 py-2 text-xs transition-colors duration-150 hover:bg-[color:var(--accent)]/5"
    >
      {img && <img src={img} alt="" class="h-3.5 w-3.5" />}
      {title}
      <div class="engine-check absolute -top-1 -right-1 hidden">
        <i data-lucide="check-circle" class="h-3 w-3 text-[color:var(--accent)]" />
      </div>
    </button>
  )
}

{
  type === 'preset' && (
    <button
      data-cloak-preset={name}
      data-preset-title={title}
      data-preset-favicon={img}
      class="bg-background/50 hover:bg-background/70 flex items-center justify-center gap-1.5 rounded-lg border border-white/5 px-2 py-1.5 text-xs transition-colors duration-150"
    >
      {img && <img src={img} class="h-3.5 w-3.5" alt="" />}
      <slot />
    </button>
  )
}
