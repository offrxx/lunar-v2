---
import '@/main.css';
import ImportLucide from '../layouts/lucide.astro';

interface Game {
  name: string;
  desc: string;
  url: string;
  icon: string;
}

const { list = [] }: { list?: Game[] } = Astro.props;
const { type = '' }: { type?: string } = Astro.props;
const sorted = [...list].sort((a, b) => a.name.localeCompare(b.name));
---

<html lang="en">
  <body class="bg-background font-linux text-text-header min-h-screen">
    <div class="mx-auto max-w-7xl p-5">
      <div class="mb-6">
        <div class="mb-5 flex items-center justify-between">
          <h1 class="text-xl font-semibold">
            {type === 'games' ? 'Lunar Games' : type === 'app' ? 'Lunar Apps' : 'Assets'}
          </h1>
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5 rounded-md border border-white/[0.08] bg-[#1e1e2f]/50 p-0.5 backdrop-blur-sm">
              <button
                data-view="grid"
                class="flex h-7 w-7 items-center justify-center rounded bg-[#252537]/60 text-white/70 transition-all duration-150"
              >
                <i data-lucide="grid-3x3" class="h-3.5 w-3.5"></i>
              </button>
              <button
                data-view="compact"
                class="flex h-7 w-7 items-center justify-center rounded text-white/50 transition-all duration-150"
              >
                <i data-lucide="layout-grid" class="h-3.5 w-3.5"></i>
              </button>
              <button
                data-view="list"
                class="flex h-7 w-7 items-center justify-center rounded text-white/50 transition-all duration-150"
              >
                <i data-lucide="list" class="h-3.5 w-3.5"></i>
              </button>
            </div>
          </div>
        </div>

        <div class="mb-4 flex flex-wrap items-center gap-2">
          <div class="relative max-w-md min-w-60 flex-1">
            <i data-lucide="search" class="absolute top-1/2 left-2.5 h-3.5 w-3.5 -translate-y-1/2 text-white/40"></i>
            <input
              type="text"
              data-input
              placeholder={`Search ${type === 'games' ? 'games' : type === 'app' ? 'apps' : 'assets'}...`}
              class="h-9 w-full rounded-md border border-white/[0.08] bg-[#1e1e2f]/40 pr-3 pl-9 text-sm text-white/80 placeholder-white/40 backdrop-blur-sm transition-colors focus:border-white/[0.15] focus:outline-none"
            />
          </div>
          <button
            data-random
            class="flex h-9 items-center gap-2 rounded-md border border-white/[0.08] bg-[#1e1e2f]/40 px-3 text-sm text-white/60 backdrop-blur-sm transition-all duration-150 hover:border-white/[0.15] hover:bg-[#1e1e2f]/60 hover:text-white/80"
          >
            <i data-lucide="shuffle" class="h-3.5 w-3.5"></i>
            Random
          </button>
          <button
            data-sort
            class="flex h-9 items-center gap-2 rounded-md border border-white/[0.08] bg-[#1e1e2f]/40 px-3 text-sm text-white/60 backdrop-blur-sm transition-all duration-150 hover:border-white/[0.15] hover:bg-[#1e1e2f]/60 hover:text-white/80"
          >
            <i data-lucide="arrow-up-down" class="h-3.5 w-3.5"></i>
            <span>A-Z</span>
          </button>
        </div>

        <div class="text-xs text-white/50">
          Showing <span data-visible class="font-medium text-white/70">{sorted.length}</span> of {sorted.length}
        </div>
      </div>

      <div data-container class="grid grid-cols-1 gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {
          sorted.map(g => (
            <div
              data-href={g.url}
              data-name={g.name}
              data-bg={g.icon}
              class="card card-loading group relative flex h-40 cursor-pointer flex-col justify-end overflow-hidden rounded-lg border border-white/[0.08] bg-[#1e1e2f]/40 backdrop-blur-sm transition-all duration-200 hover:border-white/[0.15] hover:bg-[#1e1e2f]/60"
              style="animation: fadeIn 0.3s ease-out"
            >
              <div class="card-bg absolute inset-0 bg-cover bg-center opacity-60 transition-opacity group-hover:opacity-75" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent" />
              <div class="relative z-10 p-3.5">
                <h2 class="mb-1 text-sm font-semibold text-white drop-shadow-lg">{g.name}</h2>
                <p class="line-clamp-2 text-xs text-gray-300/90 drop-shadow-md">{g.desc}</p>
              </div>
            </div>
          ))
        }
      </div>

      <div data-empty class="hidden flex-col items-center justify-center py-16 text-center">
        <div class="rounded-lg border border-white/[0.08] bg-[#1e1e2f]/40 p-8 backdrop-blur-sm">
          <i data-lucide="inbox" class="mx-auto mb-3 h-10 w-10 text-white/30"></i>
          <h3 class="mb-1 text-base font-semibold text-white/80">No assets found</h3>
          <p class="text-sm text-white/50">Try a different search</p>
        </div>
      </div>
    </div>

    <ImportLucide />
    <script src="../utils/assets"></script>
    <style>
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </body>
</html>
